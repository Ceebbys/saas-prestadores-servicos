# =============================================================================
# ServiçoPro — Environment Variables
# =============================================================================

# --- Django Core ---
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=your-secret-key-here
DEBUG=True

# --- Database ---
# Option 1: DATABASE_URL (used by Render / production)
# DATABASE_URL=postgresql://user:password@host:5432/saas_prestadores

# Option 2: Individual vars (used by local dev when not using DATABASE_URL)
DB_NAME=saas_prestadores
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Option 3: SQLite for quick local dev (only works with config.settings.dev)
USE_SQLITE=true

# --- Hosts ---
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Production only (Render sets RENDER_EXTERNAL_HOSTNAME automatically) ---
# CSRF_TRUSTED_ORIGINS=https://your-app.onrender.com
# SECURE_SSL_REDIRECT=true

# --- Demo ---
# DEMO_SEED=true  # Required to run reset_demo_data in production

# --- Evolution API (WhatsApp gratuito via Docker) ---
# Instale: docker run -d --name evolution-api -p 8080:8080 -e AUTHENTICATION_API_KEY=sua-chave atendai/evolution-api:v2.1.1
# EVOLUTION_API_URL=http://localhost:8080
# EVOLUTION_API_KEY=sua-chave-api
# EVOLUTION_INSTANCE_NAME=saas-whatsapp
# EVOLUTION_WEBHOOK_TOKEN=token-secreto-para-webhook
